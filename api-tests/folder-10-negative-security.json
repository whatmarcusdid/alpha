{
  "name": "10 — Negative / Security / Abuse Cases",
  "description": "Adversarial cross-section: public (audit, checkout, order-status), authenticated (confirm-details, create-account), admin (fix-jobs). Every test asserts status codes AND response bodies contain no stack traces, file paths, or node_modules leaks. Rate-limit burst may not 429 locally when Upstash is unreachable (fail-open) — documented as FINDING, not a pass on broken behavior.",
  "item": [
    {
      "name": "Setup — capture token before revoke (Folder 10 auth abuse)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "pm.environment.set('folder10TokenBeforeRevoke', pm.environment.get('userToken') || '');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('folder10TokenBeforeRevoke captured', () => {",
              "  pm.expect(pm.environment.get('folder10TokenBeforeRevoke')).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/audit — malformed JSON (400, not 500)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"firstName\":\"API\",\"businessName\":\"Test\","
        },
        "url": "{{baseUrl}}/api/audit"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.text();",
              "pm.test('Status is 400', () => pm.response.to.have.status(400));",
              "pm.test('Invalid input error', () => pm.expect(pm.response.json().error).to.eql('Invalid input'));",
              "pm.test('Not a 500', () => pm.expect(pm.response.code).to.be.below(500));",
              "pm.test('No stack trace or internal paths in body', () => {",
              "  pm.expect(body).to.not.match(/\\bat\\s+[\\w./]+:\\d+:\\d+/);",
              "  pm.expect(body).to.not.include('node_modules');",
              "  pm.expect(body).to.not.include('/Users/');",
              "  pm.expect(body).to.not.include('.next/');",
              "});"
            ]
          }
        }
      ]
    },
