    {
      "name": "Rate-limit burst — POST /api/book-service/create-account (429 or fail-open FINDING)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const baseUrl = pm.environment.get('baseUrl');",
              "const burstCount = 8;",
              "let saw429 = false;",
              "let saw500 = false;",
              "const pending = [];",
              "for (let i = 0; i < burstCount; i++) {",
              "  pending.push(new Promise((resolve) => {",
              "    pm.sendRequest({",
              "      url: `${baseUrl}/api/book-service/create-account`,",
              "      method: 'POST',",
              "      header: { 'Content-Type': 'application/json' },",
              "      body: { mode: 'raw', raw: '{}' },",
              "    }, (err, res) => {",
              "      if (res && res.code === 429) saw429 = true;",
              "      if (res && res.code >= 500) saw500 = true;",
              "      resolve(res);",
              "    });",
              "  }));",
              "}",
              "Promise.all(pending).then(() => {",
              "  pm.test('Burst: no 500 responses', () => pm.expect(saw500).to.eql(false));",
              "  if (saw429) {",
              "    pm.test('Burst: 429 rate limit observed', () => pm.expect(saw429).to.eql(true));",
              "  } else {",
              "    pm.test('FINDING: no 429 — Upstash fail-open or limiter not configured locally', () => {",
              "      pm.expect(saw429).to.eql(false);",
              "    });",
              "  }",
              "});"
            ]
          }
        }
      ]
    },
