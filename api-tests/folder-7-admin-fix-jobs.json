    {
      "name": "PATCH /api/admin/fix-jobs/:fixJobId/progress — happy path (phase0 + signals)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"uid\": \"{{userId}}\",\n  \"action\": { \"type\": \"set_phase0\", \"complete\": true }\n}"
        },
        "url": "{{baseUrl}}/api/admin/fix-jobs/{{fixJobId}}/progress"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Phase0 status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Phase0 success', () => pm.expect(pm.response.json().success).to.eql(true));",
              "const baseUrl = pm.environment.get('baseUrl');",
              "const uid = pm.environment.get('userId');",
              "const fixJobId = pm.environment.get('fixJobId');",
              "const adminToken = pm.environment.get('adminToken');",
              "pm.sendRequest({",
              "  url: `${baseUrl}/api/admin/fix-jobs/${fixJobId}?uid=${uid}`,",
              "  method: 'GET',",
              "  header: { Authorization: `Bearer ${adminToken}` },",
              "}, (err, detailRes) => {",
              "  pm.test('Firestore phase0Complete=true', () => {",
              "    pm.expect(err).to.be.null;",
              "    pm.expect(detailRes.json().data.phase0Complete).to.eql(true);",
              "  });",
              "  const progress = detailRes.json().data.fixProgress || {};",
              "  const signalKeys = Object.keys(progress).filter((k) => Array.isArray(progress[k].completedStepIds));",
              "  if (signalKeys.length === 0) {",
              "    pm.test('No signal keys to complete (empty speedTopIssues baseline)', () => pm.expect(signalKeys.length).to.eql(0));",
              "    return;",
              "  }",
              "  let remaining = signalKeys.length;",
              "  signalKeys.forEach((signalKey) => {",
              "    pm.sendRequest({",
              "      url: `${baseUrl}/api/admin/fix-jobs/${fixJobId}/progress`,",
              "      method: 'PATCH',",
              "      header: { Authorization: `Bearer ${adminToken}`, 'Content-Type': 'application/json' },",
              "      body: { mode: 'raw', raw: JSON.stringify({ uid, signalKey, action: { type: 'set_status', status: 'done' } }) },",
              "    }, (sigErr, sigRes) => {",
              "      remaining -= 1;",
              "      pm.test(`Signal ${signalKey} marked done`, () => {",
              "        pm.expect(sigErr).to.be.null;",
              "        pm.expect(sigRes.code).to.eql(200);",
              "      });",
              "      if (remaining === 0) {",
              "        pm.sendRequest({",
              "          url: `${baseUrl}/api/admin/fix-jobs/${fixJobId}?uid=${uid}`,",
              "          method: 'GET',",
              "          header: { Authorization: `Bearer ${adminToken}` },",
              "        }, (vErr, vRes) => {",
              "          pm.test('All signals done or N/A in Firestore', () => {",
              "            pm.expect(vErr).to.be.null;",
              "            const fp = vRes.json().data.fixProgress;",
              "            const incomplete = Object.entries(fp).filter(([k, e]) => Array.isArray(e.completedStepIds) && e.status !== 'done' && e.status !== 'not_applicable');",
              "            pm.expect(incomplete.length).to.eql(0);",
              "          });",
              "        });",
              "      }",
              "    });",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
