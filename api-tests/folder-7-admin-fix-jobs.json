{
  "name": "7 — Admin Fix Jobs (full pipeline)",
  "description": "Admin fix-job pipeline per test plan §3.5. Seeds from Folders 1–2 chained fixSession (orderId=fixJobId, userId, adminToken). Stage transitions use PATCH /stage (required by route code). QA is PATCH (not POST). Report path is POST /report/generate. Verifies Firestore state via GET /api/admin/fix-jobs/:id?uid= after each stage change.",
  "item": [
    {
      "name": "GET fix job detail — verify seed (stage=ready)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/admin/fix-jobs/{{fixJobId}}?uid={{userId}}"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "if (!pm.environment.get('userId') || !pm.environment.get('fixJobId') || !pm.environment.get('adminToken')) {",
              "  throw new Error('userId, fixJobId, adminToken required — run Folders 1–2 first.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Fix session seeded', () => {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.sessionId).to.eql(pm.environment.get('fixJobId'));",
              "  pm.expect(json.data.uid).to.eql(pm.environment.get('userId'));",
              "});",
              "pm.test('Stage is ready after submit-access', () => pm.expect(json.data.stage).to.eql('ready'));",
              "pm.collectionVariables.set('adminPipelineInitialStage', json.data.stage);",
              "pm.environment.set('adminPipelineInitialStage', json.data.stage);"
            ]
          }
        }
      ]
    },
