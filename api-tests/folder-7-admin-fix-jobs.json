    {
      "name": "POST /api/admin/fix-jobs/:fixJobId/deliver — happy path",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"uid\": \"{{userId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/admin/fix-jobs/{{fixJobId}}/deliver"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const code = pm.response.code;",
              "if (code === 409) {",
              "  pm.test('Status is 409 when report not generated', () => pm.response.to.have.status(409));",
              "  pm.test('409 error message', () => {",
              "    pm.expect(pm.response.json().error).to.match(/Generate the report first|Already delivered/i);",
              "  });",
              "} else if (code === 500) {",
              "  pm.test('[FINDING] deliver 500 — PDF fetch or Loops email unconfigured locally', () => {",
              "    pm.expect(pm.response.json().error).to.match(/Failed to load report PDF|Failed to send delivery email/i);",
              "  });",
              "} else if (code === 200) {",
              "  pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "  pm.test('sentAt returned', () => pm.expect(pm.response.json().data.sentAt).to.be.a('string'));",
              "  const baseUrl = pm.environment.get('baseUrl');",
              "  const uid = pm.environment.get('userId');",
              "  const fixJobId = pm.environment.get('fixJobId');",
              "  const adminToken = pm.environment.get('adminToken');",
              "  pm.sendRequest({",
              "    url: `${baseUrl}/api/admin/fix-jobs/${fixJobId}?uid=${uid}`,",
              "    method: 'GET',",
              "    header: { Authorization: `Bearer ${adminToken}` },",
              "  }, (err, res) => {",
              "    pm.test('Firestore stage is delivered', () => pm.expect(res.json().data.stage).to.eql('delivered'));",
              "    pm.test('Firestore report.status is sent', () => pm.expect(res.json().data.reportData.status).to.eql('sent'));",
              "  });",
              "} else {",
              "  pm.test('Unexpected deliver status', () => pm.expect.fail(`Unexpected status ${code}`));",
              "}"
            ]
          }
        }
      ]
    },
