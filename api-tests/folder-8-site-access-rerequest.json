            "exec": [
              "pm.test('Status is 400 on reused token', () => pm.response.to.have.status(400));",
              "pm.test('Generic invalid/expired error (tokenUsed excludes doc from lookup)', () => {",
              "  pm.expect(pm.response.json().error).to.eql('Invalid or expired access link');",
              "});"
            ]
          }
        }
      ]
    },
    {
