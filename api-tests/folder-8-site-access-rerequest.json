{
  "name": "8 — Site Access Re-Request Flow",
  "description": "Admin site-access re-request flow. Chains userId/fixJobId/adminToken from Folders 1–7. Verifies Firestore state via emulator-only GET /api/test/smoke/site-access-request. devAccessToken exposed when FIREBASE_AUTH_EMULATOR_HOST is set (same pattern as Folder 5 devResetToken).",
  "item": [
    {
      "name": "POST /api/admin/site-access/request — happy path",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"uid\": \"{{userId}}\",\n  \"sessionId\": \"{{fixJobId}}\",\n  \"accessType\": \"wp_admin\",\n  \"scopeDescription\": \"API smoke: re-request updated WordPress admin credentials for grant flow.\",\n  \"expiryDays\": 7\n}"
        },
        "url": "{{baseUrl}}/api/admin/site-access/request"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "if (!pm.environment.get('userId') || !pm.environment.get('fixJobId') || !pm.environment.get('adminToken')) {",
              "  throw new Error('userId, fixJobId, adminToken required — run Folders 1–7 first.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('success=true', () => pm.expect(json.success).to.eql(true));",
              "pm.test('requestId returned', () => {",
              "  pm.expect(json.data.requestId).to.be.a('string').and.not.empty;",
              "  pm.environment.set('siteAccessRequestId', json.data.requestId);",
              "});",
              "pm.test('devAccessToken returned in emulator', () => {",
              "  pm.expect(json.devAccessToken).to.be.a('string').and.not.empty;",
              "  pm.environment.set('grantedToken', json.devAccessToken);",
              "});",
              "const baseUrl = pm.environment.get('baseUrl');",
              "const requestId = json.data.requestId;",
              "pm.sendRequest({",
              "  url: `${baseUrl}/api/test/smoke/site-access-request?requestId=${requestId}`,",
              "  method: 'GET',",
              "}, (err, res) => {",
              "  pm.test('Firestore: new request is pending', () => {",
              "    pm.expect(err).to.be.null;",
              "    pm.expect(res.json().data.status).to.eql('pending');",
              "    pm.expect(res.json().data.tokenUsed).to.eql(false);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/admin/site-access/request — duplicate pending (409)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"uid\": \"{{userId}}\",\n  \"sessionId\": \"{{fixJobId}}\",\n  \"accessType\": \"wp_admin\",\n  \"scopeDescription\": \"API smoke: duplicate pending should be rejected by route.\",\n  \"expiryDays\": 7\n}"
        },
        "url": "{{baseUrl}}/api/admin/site-access/request"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 409 (pending request already exists)', () => pm.response.to.have.status(409));",
              "pm.test('Conflict error message', () => {",
              "  pm.expect(pm.response.json().error).to.eql('A pending access request already exists for this job');",
              "});",
              "const baseUrl = pm.environment.get('baseUrl');",
              "const requestId = pm.environment.get('siteAccessRequestId');",
              "pm.sendRequest({",
              "  url: `${baseUrl}/api/test/smoke/site-access-request?requestId=${requestId}`,",
              "  method: 'GET',",
              "}, (err, res) => {",
              "  pm.test('Firestore: original pending request unchanged', () => {",
              "    pm.expect(err).to.be.null;",
              "    pm.expect(res.json().data.status).to.eql('pending');",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/site-access/grant — happy path",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{grantedToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/site-access/grant"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('success=true', () => pm.expect(json.success).to.eql(true));",
              "pm.test('expiresAt returned', () => {",
              "  pm.expect(json.data.expiresAt).to.be.a('string').and.not.empty;",
              "  pm.environment.set('siteAccessGrantedExpiresAt', json.data.expiresAt);",
              "});",
              "const baseUrl = pm.environment.get('baseUrl');",
              "const requestId = pm.environment.get('siteAccessRequestId');",
              "pm.sendRequest({",
              "  url: `${baseUrl}/api/test/smoke/site-access-request?requestId=${requestId}`,",
              "  method: 'GET',",
              "}, (err, res) => {",
              "  pm.test('Firestore: status is granted', () => {",
              "    pm.expect(err).to.be.null;",
              "    pm.expect(res.json().data.status).to.eql('granted');",
              "  });",
              "  pm.test('Firestore: tokenUsed=true after grant', () => {",
              "    pm.expect(res.json().data.tokenUsed).to.eql(true);",
              "  });",
              "  pm.test('Firestore: expiresAt set', () => {",
              "    pm.expect(res.json().data.expiresAt).to.be.a('string').and.not.empty;",
              "  });",
              "  pm.test('Firestore: grantedAt set', () => {",
              "    pm.expect(res.json().data.grantedAt).to.be.a('string').and.not.empty;",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/site-access/grant — reused token (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{grantedToken}}\"\n}"
