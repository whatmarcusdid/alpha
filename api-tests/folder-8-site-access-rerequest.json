    {
      "name": "GET /api/cron/expire-access-requests — happy path",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/cron/expire-access-requests"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const cronSecret = pm.environment.get('cronSecret');",
              "if (cronSecret) {",
              "  pm.request.headers.add({ key: 'Authorization', value: `Bearer ${cronSecret}` });",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('success=true', () => pm.expect(json.success).to.eql(true));",
              "pm.test('expired count is at least 1', () => {",
              "  pm.expect(json.data.expired).to.be.at.least(1);",
              "});",
              "const baseUrl = pm.environment.get('baseUrl');",
              "const requestId = pm.environment.get('expireSiteAccessRequestId');",
              "pm.sendRequest({",
              "  url: `${baseUrl}/api/test/smoke/site-access-request?requestId=${requestId}`,",
              "  method: 'GET',",
              "}, (err, res) => {",
              "  pm.test('Firestore: status is expired after cron', () => {",
              "    pm.expect(err).to.be.null;",
              "    pm.expect(res.json().data.status).to.eql('expired');",
              "  });",
              "});"
            ]
          }
        }
      ]
