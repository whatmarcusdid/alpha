          "raw": "{\n  \"uid\": \"{{userId}}\",\n  \"sessionId\": \"{{fixJobId}}\",\n  \"accessType\": \"hosting_panel\",\n  \"scopeDescription\": \"API smoke: separate pending request for decline flow testing.\",\n  \"expiryDays\": 3\n}"
