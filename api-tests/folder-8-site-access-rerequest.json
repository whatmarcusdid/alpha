    {
      "name": "PATCH smoke — backdate expiresAt for cron test",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"backdateExpiresAt\": true\n}"
        },
        "url": "{{baseUrl}}/api/test/smoke/site-access-request?requestId={{expireSiteAccessRequestId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('expiresAt backdated to past', () => {",
              "  pm.expect(json.data.expiresAt).to.be.a('string');",
              "  pm.expect(new Date(json.data.expiresAt).getTime()).to.be.below(Date.now());",
              "});"
            ]
          }
        }
