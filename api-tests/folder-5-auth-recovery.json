{
  "name": "5 — Auth & Account Recovery",
  "description": "Auth boundary checks (run before password reset — reset revokes existing ID tokens) + password reset flow. Chains testEmail/userToken/userId from Folders 1–2. Reset tokens are app-generated Firestore passwordResets/{token}, not Firebase Auth OOB — devResetToken returned when FIREBASE_AUTH_EMULATOR_HOST is set. Unknown-email test asserts identical generic success response (anti-enumeration).",
  "item": [
    {
      "name": "PATCH protected route — no auth header (401)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"businessName\": \"Bright Path Pressure Washing\",\n  \"websiteUrl\": \"https://brightpathpw.com\",\n  \"contactName\": \"API\",\n  \"contactEmail\": \"{{testEmail}}\"\n}"
        },
        "url": "{{baseUrl}}/api/book-service/confirm-details"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', () => pm.response.to.have.status(401));",
              "pm.test('Unauthorized error shape', () => {",
              "  pm.expect(pm.response.json().error).to.match(/Unauthorized|authentication token/i);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH protected route — invalid token (401)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "not-a-valid-firebase-jwt", "type": "string" }]
        },
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"businessName\": \"Bright Path Pressure Washing\",\n  \"websiteUrl\": \"https://brightpathpw.com\",\n  \"contactName\": \"API\",\n  \"contactEmail\": \"{{testEmail}}\"\n}"
        },
        "url": "{{baseUrl}}/api/book-service/confirm-details"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', () => pm.response.to.have.status(401));",
              "pm.test('Invalid token error', () => {",
              "  pm.expect(pm.response.json().error).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET admin route — valid non-admin token (403)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/admin/fix-jobs/{{orderId}}?uid={{userId}}"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('userToken')) {",
              "  throw new Error('userToken required — run create-account first.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 403 Forbidden', () => pm.response.to.have.status(403));",
              "pm.test('Forbidden error message', () => pm.expect(pm.response.json().error).to.eql('Forbidden'));"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/auth/request-password-reset — happy path (known email)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/request-password-reset"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "if (!pm.environment.get('testEmail')) {",
              "  throw new Error('testEmail required — run Folders 1–2 create-account first.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('success=true', () => pm.expect(json.success).to.eql(true));",
              "pm.test('Generic success message (no account-existence leak)', () => {",
              "  pm.expect(json.message).to.eql('If an account exists with this email, you will receive password reset instructions shortly.');",
              "});",
              "pm.test('devResetToken returned in emulator (custom Firestore token, not Firebase OOB)', () => {",
              "  pm.expect(json.devResetToken).to.match(/^[a-f0-9]{64}$/);",
              "  pm.environment.set('passwordResetToken', json.devResetToken);",
              "});",
              "pm.environment.set('pwdResetKnownStatus', String(pm.response.code));",
              "pm.environment.set('pwdResetKnownSuccess', String(json.success));",
              "pm.environment.set('pwdResetKnownMessage', json.message);"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/auth/request-password-reset — unknown email (anti-enumeration)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{unknownTestEmail}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/request-password-reset"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "const unknown = `no-such-user-${Date.now()}@bookservice.test`;",
              "pm.environment.set('unknownTestEmail', unknown);",
              "pm.collectionVariables.set('unknownTestEmail', unknown);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('Status matches known-email response', () => {",
              "  pm.expect(String(pm.response.code)).to.eql(pm.environment.get('pwdResetKnownStatus'));",
              "});",
              "pm.test('success flag matches known-email response', () => {",
              "  pm.expect(String(json.success)).to.eql(pm.environment.get('pwdResetKnownSuccess'));",
              "});",
              "pm.test('Message identical to known-email response (no enumeration signal)', () => {",
              "  pm.expect(json.message).to.eql(pm.environment.get('pwdResetKnownMessage'));",
              "});",
              "pm.test('Response does not mention account not found', () => {",
              "  const body = JSON.stringify(json).toLowerCase();",
              "  pm.expect(body).to.not.match(/not found|does not exist|no account|unknown email|invalid user/);",
              "});",
              "pm.test('devResetToken absent for unknown email', () => {",
              "  pm.expect(json.devResetToken).to.be.undefined;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/auth/reset-password — validate token",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/auth/reset-password?token={{passwordResetToken}}"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "if (!pm.environment.get('passwordResetToken')) {",
              "  throw new Error('passwordResetToken required — run request-password-reset happy path first.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 (route returns 200 for valid and invalid tokens)', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Token is valid', () => pm.expect(json.valid).to.eql(true));",
              "pm.test('Email returned matches test account', () => {",
              "  pm.expect(json.email).to.eql(pm.environment.get('testEmail').toLowerCase());",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/auth/reset-password — apply new password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{passwordResetToken}}\",\n  \"password\": \"{{resetPasswordNewPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/reset-password"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.collectionVariables.get('runMutatingSmoke') !== 'true') { pm.execution.skipRequest(); }",
              "if (!pm.environment.get('passwordResetToken')) {",
              "  throw new Error('passwordResetToken required.');",
              "}",
              "const newPw = pm.environment.get('resetPasswordNewPassword') || 'api-smoke-reset-password-456';",
              "pm.environment.set('resetPasswordNewPassword', newPw);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('success=true', () => pm.expect(json.success).to.eql(true));",
              "pm.test('Success message present', () => {",
              "  pm.expect(json.message).to.match(/password has been reset successfully/i);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/auth/reset-password — reused token (single-use)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{passwordResetToken}}\",\n  \"password\": \"another-password-789\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/reset-password"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400 (token already used)', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('Error mentions already used', () => {",
              "  pm.expect(json.error).to.match(/already been used/i);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
