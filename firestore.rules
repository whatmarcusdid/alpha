rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Password resets — server-only via Admin SDK
    match /passwordResets/{tokenId} {
      allow read, write: if false;
    }

    // auditLeads — server-only via Admin SDK
    match /auditLeads/{auditId} {
      allow read, write: if false;
    }

    // Admin fix jobs — server-only via Admin SDK
    match /fixJobs/{fixJobId} {
      allow read, write: if false;

      match /loops/{loopKey} {
        allow read, write: if false;
      }

      match /approvals/{approvalId} {
        allow read, write: if false;
      }

      match /qa/{qaDocId} {
        allow read, write: if false;
      }

      match /reports/{reportId} {
        allow read, write: if false;
      }

      match /accessRevocations/{credentialType} {
        allow read, write: if false;
      }
    }

    // Admin metadata (display-ID counter) — server-only via Admin SDK
    match /meta/{docId} {
      allow read, write: if false;
    }

    // adminAuditLog: server-only via Admin SDK. No client access.
    match /adminAuditLog/{logId} {
      allow read, write: if false;
    }

    // User profiles — authenticated user can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Reports subcollection — read-only for the owning user
      match /reports/{reportId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // Fix sessions — read-only for the owning user, admin writes only
      match /fixSessions/{sessionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
        // Admin fulfillment fields (stage, fixProgress, qa, afterAudit, report, etc.) are written
        // exclusively via Firebase Admin SDK in API routes. No client-write rules are added for these fields.
        // Client read of own fixSession is handled by the existing rule above.
      }

      // Client-facing fix updates — read-only for the owning user, admin writes only
      match /fixUpdates/{updateId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Support tickets — authenticated user can create and read their own
    match /supportTickets/{ticketId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Pending subscriptions — server-only
    match /pending_subscriptions/{email} {
      allow read, write: if false;
    }

    // Sites — authenticated user can read their own site records
    match /sites/{siteId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

  }
}
